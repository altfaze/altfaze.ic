generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @map("updated_at")
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model User {
  id                     String             @id @default(cuid())
  name                   String?
  email                  String?            @unique
  emailVerified          DateTime?
  password               String?
  image                  String?
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @default(now()) @map("updated_at")
  hasPaid                Boolean?           @default(false)
  username               String?            @unique
  isVerified             Boolean            @default(false)
  isSuspended            Boolean            @default(false)
  lastLogin              DateTime?
  role                   String?
  walletBalance          Decimal            @default(0) @db.Decimal(12, 2)
  totalSpent             Decimal            @default(0) @db.Decimal(12, 2)
  totalEarned            Decimal            @default(0) @db.Decimal(12, 2)
  razorpayCustomerId     String?            @unique @map("razorpay_customer_id")
  razorpayContactId      String?            @unique @map("razorpay_contact_id")
  razorpayFundAccountId  String?            @map("razorpay_fund_account_id")
  accounts               Account[]
  activities             ActivityLog[]
  client                 Client?
  freelancer             Freelancer?
  notifications          Notification[]
  offersReceived         Offer[]            @relation("OfferReceiver")
  offersSent             Offer[]            @relation("OfferSender")
  ordersReceived         Order[]            @relation("OrderReceiver")
  ordersSent             Order[]            @relation("OrderSender")
  posts                  Post[]
  projectsCreated        Project[]          @relation("ProjectCreator")
  projectsSubmitted      Project[]          @relation("ProjectSubmitter")
  requestsReceived       Request[]          @relation("RequestReceiver")
  requestsSent           Request[]          @relation("RequestSender")
  reviewsGiven           Review[]           @relation("ReviewAuthor")
  reviewsReceived        Review[]           @relation("ReviewTarget")
  sessions               Session[]
  templatePurchases      TemplatePurchase[]
  transactions           Transaction[]
  messagesSent           Message[]          @relation("MessageSender")
  messagesReceived       Message[]          @relation("MessageReceiver")
  conversationParticipants ConversationParticipant[]

  @@index([email])
  @@index([role])
  @@index([isSuspended])
  @@index([createdAt])
  @@map("users")
}

model Freelancer {
  id                  String   @id @default(cuid())
  userId              String   @unique
  title               String?
  bio                 String?
  skills              String[]
  portfolio           String?
  hourlyRate          Decimal? @db.Decimal(10, 2)
  rating              Decimal  @default(0) @db.Decimal(3, 2)
  reviewCount         Int      @default(0)
  minimumHourlyRate   Decimal? @default(0) @db.Decimal(10, 2)
  preferredCategories String[] @default([])
  isAvailable         Boolean  @default(false)
  status              String   @default("OFFLINE") // OFFLINE | ONLINE | BUSY
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("freelancers")
}

model Client {
  id          String   @id @default(cuid())
  userId      String   @unique
  company     String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("clients")
}

model Template {
  id          String             @id @default(cuid())
  title       String
  description String?
  category    String
  image       String?
  price       Decimal            @db.Decimal(10, 2)
  features    String[]
  uploaderId  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  activities  ActivityLog[]
  purchases   TemplatePurchase[]

  @@index([uploaderId])
  @@map("templates")
}

model TemplatePurchase {
  id            String   @id @default(cuid())
  templateId    String
  userId        String
  purchasePrice Decimal  @db.Decimal(10, 2)
  downloadToken String   @unique
  status        String   @default("COMPLETED")
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([templateId])
  @@index([userId])
  @@index([transactionId])
  @@map("template_purchases")
}

model Project {
  id          String    @id @default(cuid())
  title       String
  description String
  budget      Decimal?  @db.Decimal(12, 2)
  status      String    @default("OPEN")
  creatorId   String
  submiterId  String?
  category    String?
  deadline    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  creator     User      @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  submitter   User?     @relation("ProjectSubmitter", fields: [submiterId], references: [id])

  @@map("projects")
}

model Request {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("PENDING")
  senderId    String
  receiverId  String
  projectId   String?
  amount      Decimal?  @db.Decimal(12, 2)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orders      Order[]
  receiver    User      @relation("RequestReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender      User      @relation("RequestSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@map("requests")
}

model Transaction {
  id                  String   @id @default(cuid())
  userId              String
  type                String
  amount              Decimal  @db.Decimal(12, 2)
  netAmount           Decimal? @db.Decimal(12, 2)
  commission          Decimal? @db.Decimal(12, 2)
  description         String?
  status              String   @default("PENDING")
  razorpayOrderId     String?  @unique @map("razorpay_order_id")
  razorpayPaymentId   String?  @unique @map("razorpay_payment_id")
  razorpayRefundId    String?  @map("razorpay_refund_id")
  senderId            String?
  receiverId          String?
  projectId           String?
  requestId           String?
  templateId          String?
  relatedResourceType String?
  relatedResourceId   String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Discount {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  discountType  String    @default("PERCENTAGE")
  discountValue Decimal   @db.Decimal(5, 2)
  maxUsage      Int?
  usageCount    Int       @default(0)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("discounts")
}

model ActivityLog {
  id           String    @id @default(cuid())
  userId       String
  action       String
  description  String?
  resourceType String?
  resourceId   String?
  metadata     Json?
  templateId   String?
  createdAt    DateTime  @default(now())
  template     Template? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model Order {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  title       String
  description String?
  amount      Decimal   @db.Decimal(12, 2)
  status      String    @default("PENDING")
  requestId   String?
  deadline    DateTime?
  acceptedAt  DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  receiver    User      @relation("OrderReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  request     Request?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender      User      @relation("OrderSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model Notification {
  id                  String   @id @default(cuid())
  userId              String
  type                String
  title               String
  message             String
  read                Boolean  @default(false)
  relatedResourceType String?
  relatedResourceId   String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model Offer {
  id          String    @id @default(cuid())
  senderId    String
  receiverId  String
  title       String
  description String?
  amount      Decimal   @db.Decimal(12, 2)
  status      String    @default("PENDING")
  deadline    DateTime?
  expiresAt   DateTime?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  receiver    User      @relation("OfferReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  sender      User      @relation("OfferSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
  @@map("offers")
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  targetId  String
  rating    Int
  comment   String?
  orderId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([authorId, targetId, orderId])
  @@index([targetId])
  @@map("reviews")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   Json?
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])

  @@map("posts")
}

model Conversation {
  id            String   @id @default(cuid())
  type          String   @default("DIRECT")
  name          String?
  participants  ConversationParticipant[]
  messages      Message[]
  lastMessageId String?
  lastMessageAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([lastMessageAt])
  @@index([createdAt])
  @@map("conversations")
}

model ConversationParticipant {
  id                String   @id @default(cuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadMessageId String?
  lastReadAt        DateTime?
  isMuted           Boolean  @default(false)
  joinedAt          DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_participants")
}

model Message {
  id                  String   @id @default(cuid())
  conversationId      String
  conversation        Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId            String
  sender              User     @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId          String
  receiver            User     @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  content             String
  attachments         String[]
  read                Boolean  @default(false)
  relatedResourceType String?
  relatedResourceId   String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model IdempotencyKey {
  key       String   @id
  method    String
  path      String
  response  Json
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
  @@map("idempotency_keys")
}
